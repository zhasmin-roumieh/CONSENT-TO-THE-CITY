# ── Firebase Realtime Database (shared inscribed terms feature) ───────────────
# Follow the setup instructions in src/lib/sharedTerms.js, then fill in below.
# For local dev: copy this file to .env and fill in your value.
# For GitHub Pages: add the value as a GitHub Secret (repo Settings → Secrets → Actions).
VITE_FIREBASE_DB_URL=https://your-project-default-rtdb.firebaseio.com

# ── AI Perception images (Cloudflare Worker URL) ──────────────────────────────
VITE_WORKER_URL=https://your-worker-name.your-username.workers.dev
