# ── Supabase (shared inscribed terms feature) ────────────────────────────────
# Follow the setup instructions in src/lib/sharedTerms.js, then fill in below.
# For local dev: copy this file to .env and fill in your values.
# For GitHub Pages: add both values as GitHub Secrets (repo Settings → Secrets → Actions).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
